# ==============================================================================
# Unified Crypto Portfolio Environment Variables
# ==============================================================================

# 1. Server Configuration
PORT=3000
NODE_ENV=development
API_TIMEOUT=30000
CORS_ORIGIN=*

# Rate Limiting & Slow Down Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
SLOW_DOWN_WINDOW_MS=900000
SLOW_DOWN_DELAY_AFTER=50
SLOW_DOWN_DELAY_MS=500

# 2. Database Configuration
MONGO_URI=mongodb://127.0.0.1:27017/crypto_portfolio

# 3. Alchemy Provider (Web3 RPC URL)
ALCHEMY_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# 4. Deployed Smart Contract Address (Transactions contract)
# Both backend and frontend can read VITE_CONTRACT_ADDRESS if CONTRACT_ADDRESS is empty
CONTRACT_ADDRESS=

# 5. CoinGecko API Configuration
# Both backend and frontend can read VITE_COINGECKO_API_KEY if COINGECKO_API_KEY is empty
COINGECKO_API_KEY=

# 6. Smart Contract Deployment (Hardhat)
# Deployer wallet private key (WITHOUT the 0x prefix)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# 7. Frontend configuration (Vite prefix required)
VITE_COINGECKO_API_KEY=
VITE_CONTRACT_ADDRESS=
VITE_ETHERSCAN_API_KEY=
