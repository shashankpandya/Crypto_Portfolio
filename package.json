{
  "name": "crypto-portfolio-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server": "cd server && npm start",
    "server:dev": "cd server && npm run dev",
    "client": "cd vite-project && npm start",
    "client:dev": "cd vite-project && npm run dev",
    "build": "cd vite-project && npm run build",
    "install:all": "npm install && cd server && npm install && cd vite-project && npm install && cd smart_contract && npm install"
  },
  "devDependencies": {
    "concurrently": "^6.5.1"
  }
}
